                  "            background-color: #121212;",
                  "            color: #e0e0e0;",
                  "            margin: 0;",
                  "            padding: 32px;",
                  "        }",
                  "        .header {",
                  "            border-left: 4px solid #facc15;",
                  "            padding-left: 16px;",
                  "            margin-bottom: 32px;",
                  "        }",
                  "        h1 {",
                  "            margin: 0;",
                  "            font-size: 24px;",
                  "            font-weight: 600;",
                  "            color: #ffffff;",
                  "            text-transform: uppercase;",
                  "            letter-spacing: 1px;",
                  "        }",
                  "        .subtitle {",
                  "            font-size: 14px;",
                  "            color: #888888;",
                  "            margin-top: 6px;",
                  "            text-transform: uppercase;",
                  "            letter-spacing: 2px;",
                  "        }",
                  "        .summary-cards {",
                  "            display: flex;",
                  "            gap: 20px;",
                  "            margin-bottom: 40px;",
                  "        }",
                  "        .card {",
                  "            background-color: #1a1a1a;",
