        {
          "name": "Attendance Report",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const attId = pm.collectionVariables.get('attendanceModuleId');",
                  "if (!attId) console.warn('Run Course Page first to get attendanceModuleId');"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const cheerio = require('cheerio');",
                  "",
                  "pm.test(\"Response contains attendance data\", function () {",
                  "    pm.expect(pm.response.text().length).to.be.above(100);",
                  "});",
                  "",
                  "// Load the HTML response into Cheerio for accurate DOM parsing",
                  "const $ = cheerio.load(pm.response.text());",
                  "const records = [];",
                  "let attended = 0;",
                  "let total = 0;",
                  "",
                  "// Extract data strictly from the main attendance table",
                  "$('table.generaltable tbody tr').each(function () {",
                  "    const dateNodes = $(this).find('td.datecol nobr');",
                  "    let dateText = \"\";",
                  "    ",
                  "    // Moodle splits Date and Time into separate <nobr> tags. We join them neatly.",
                  "    if (dateNodes.length > 0) {",
                  "        dateText = dateNodes.map((i, el) => $(el).text().trim()).get().join(' | ');",
                  "    } else {",
                  "        dateText = $(this).find('td.datecol').text().trim().replace(/\\s+/g, ' ');",
                  "    }",
                  "",
                  "    if (!dateText) return; // Skip non-data rows",
                  "",
                  "    const description = $(this).find('td.desccol').text().trim().replace(/\\s+/g, ' ') || 'Regular class session';",
                  "    const statusText = $(this).find('td.statuscol').text().trim();",
                  "    const points = $(this).find('td.pointscol').text().trim();",
                  "    ",
                  "    let status = 'Unknown';",
                  "    ",
                  "    // Evaluate status logically based on points and text",
                  "    if (points.includes('1 /') || statusText.toLowerCase() === 'present') {",
                  "        status = 'Present';",
                  "        attended++;",
                  "        total++;",
                  "    } else if (points.includes('0 /') || statusText.toLowerCase() === 'absent') {",
                  "        status = 'Absent';",
                  "        total++;",
                  "    } else if (points.includes('?')) {",
                  "        status = 'Unknown';",
                  "    }",
                  "",
                  "    records.push({",
                  "        date: dateText,",
                  "        description: description,",
                  "        status: status,",
                  "        points: points",
                  "    });",
                  "});",
                  "",
                  "const pct = total > 0 ? Math.round((attended / total) * 100) : 0;",
                  "",
                  "// HTML/CSS Template for Premium Dark Gray & Yellow Accent Visualization",
                  "const template = `",
                  "<!DOCTYPE html>",
                  "<html lang=\"en\">",
                  "<head>",
                  "    <meta charset=\"UTF-8\">",
                  "    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">",
                  "    <style>",
                  "        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap');",
                  "        ",
