                  "            <div class=\"card-title\">Total Sessions</div>",
                  "            <div class=\"card-value\">{{total}}</div>",
                  "        </div>",
                  "        <div class=\"card\">",
                  "            <div class=\"card-title\">Sessions Attended</div>",
