  "item": [
    {
      "name": "Login",
      "item": [
        {
          "name": "1. Get Login token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const html = pm.response.text();",
                  "const patterns = [/name=[\"']logintoken[\"'][^>]*value=[\"']([^\"']+)[\"']/i,/value=[\"']([^\"']+)[\"'][^>]*name=[\"']logintoken[\"']/i,/[\"']logintoken[\"']\\s*[:=]\\s*[\"']([^\"']+)[\"']/i];",
                  "let token = null;",
                  "for (const re of patterns) { const m = html.match(re); if (m && m[1]) { token = m[1]; break; } }",
                  "if (token) { pm.collectionVariables.set('logintoken', token); console.log('logintoken:', token); pm.test('logintoken extracted: ' + token.substring(0, 20) + '...', () => pm.expect(token).to.be.a('string')); } else { console.log('logintoken: NOT FOUND'); pm.test('logintoken extracted', () => pm.expect.fail('logintoken not found')); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "User-Agent",
                "value": "Mozilla/5.0 (Linux; Android 10) AppleWebKit/537.36 Chrome/91.0.4472.120 Mobile"
              },
              {
                "key": "Accept",
                "value": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/login/index.php",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "login",
                "index.php"
              ]
            },
            "description": "Fetches the login page HTML.\n\n**Output**: initial cookies and a CSRF token (logintoken) extracted from a hidden form field. The token is required for the next step."
          },
          "response": []
        },
        {
          "name": "2. Submit Login Form",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const html = pm.response.text();",
                  "const hasLoginForm = /name=[\"']logintoken[\"']|id=[\"']login[\"']/i.test(html);",
                  "const hasUserMenu = /usermenu|userloggedinas|loggedin-user/i.test(html);",
                  "const hasLogoutLink = /href=[\"'][^\"']*logout/i.test(html);",
                  "const hasSesskey = /\"sesskey\":\"[^\"]+\"/i.test(html);",
                  "const hasError = /loginerrors|alert-danger|loginerrormessage/i.test(html);",
                  "const success = (hasUserMenu || hasLogoutLink || (hasSesskey && !hasLoginForm)) && !hasError;",
                  "pm.test('Login successful', () => pm.expect(success).to.be.true);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              },
              {
                "key": "User-Agent",
                "value": "Mozilla/5.0 (Linux; Android 10) AppleWebKit/537.36 Chrome/91.0.4472.120 Mobile"
              },
              {
                "key": "Accept",
                "value": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "anchor",
                  "value": ""
                },
                {
                  "key": "logintoken",
                  "value": "{{logintoken}}"
                },
                {
                  "key": "username",
                  "value": "{{vault:lms-username}}"
                },
                {
                  "key": "password",
                  "value": "{{vault:lms-password}}"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/login/index.php",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "login",
                "index.php"
              ]
            },
            "description": "Posts credentials with the login token.  \n**Output**: session cookies in Set-Cookie header. On success, redirects to dashboard. On failure, returns login page with error message."
          },
          "response": []
        },
        {
          "name": "3. Get Sesskey",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const html = pm.response.text();",
                  "const hasUserMenu = /usermenu|userloggedinas|loggedin-user/i.test(html);",
                  "const hasLogoutLink = /href=[\"'][^\"']*logout/i.test(html);",
                  "const hasSesskey = /\"sesskey\":\"[^\"]+\"/i.test(html);",
                  "const hasLoginForm = /name=[\"']logintoken[\"']|id=[\"']login[\"']/i.test(html);",
                  "const valid = hasUserMenu || hasLogoutLink || (hasSesskey && !hasLoginForm);",
                  "pm.test('Session valid', () => pm.expect(valid).to.be.true);",
                  "const m = html.match(/\"sesskey\":\"([^\"]+)\"/);",
                  "if (m) pm.collectionVariables.set('sesskey', m[1]);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "User-Agent",
                "value": "Mozilla/5.0 (Linux; Android 10) AppleWebKit/537.36 Chrome/91.0.4472.120 Mobile"
              },
              {
                "key": "Accept",
                "value": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/my/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "my",
                ""
              ]
            },
            "description": "Loads the user dashboard.  \n**Output**: HTML with embedded sesskey.  \nCookies vs sesskey: cookies are sent automatically by the browser and prove who you are (session identity). Sesskey is a CSRF token that must be sent explicitly in the URL for state-changing routes (e.g. lib/ajax/service.php). It prevents cross-site requests from using your session. Both are required for Moodle AJAX API calls."
          },
          "response": []
        }
      ],
      "description": "Authentication flow. Run steps 1, 2, 3 in order. Output: session cookies and sesskey for API calls."
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Timeline Events (Upcoming + Overdue)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const now = Math.floor(Date.now() / 1000);",
                  "const past = now - 30 * 24 * 60 * 60;",
                  "pm.collectionVariables.set('nowSec', now);",
                  "pm.collectionVariables.set('pastSec', past);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "const upcoming = data[0]?.data?.events || [];",
                  "const overdue = (data[1]?.data?.events || []).map(e => ({ ...e, overdue: true }));",
                  "const all = [...overdue, ...upcoming];",
                  "pm.test('API success', () => pm.expect(Array.isArray(data)).to.be.true);",
                  "pm.test('No API error', () => pm.expect(data[0]?.error).to.not.be.true);",
                  "const formatDate = (ts) => new Date(ts * 1000).toLocaleString();",
                  "const rows = all.map(e => ({ name: e.name || e.activityname, course: e.course?.fullname || '-', due: formatDate(e.timesort || e.timestart), overdue: !!e.overdue }));",
                  "pm.visualizer.set(`<!DOCTYPE html><html><head><meta charset=utf-8><style>body{font-family:system-ui;font-size:13px;margin:16px;color:#222;background:#fff}table{border-collapse:collapse;width:100%}th,td{padding:8px;text-align:left;border-bottom:1px solid #ddd}th{font-weight:600;color:#444}.overdue{color:#b91c1c}.upcoming{color:#15803d}</style></head><body><h2>Timeline Events</h2><p>Overdue: ${overdue.length} | Upcoming: ${upcoming.length}</p><table><tr><th>Name</th><th>Course</th><th>Due</th><th>Status</th></tr>{{#each rows}}<tr><td>{{name}}</td><td>{{course}}</td><td>{{due}}</td><td class=\"{{#if overdue}}overdue{{else}}upcoming{{/if}}\">{{#if overdue}}overdue{{else}}upcoming{{/if}}</td></tr>{{/each}}</table></body></html>`, { rows });"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "User-Agent",
                "value": "Mozilla/5.0 (Linux; Android 10) AppleWebKit/537.36 Chrome/91.0.4472.120 Mobile"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"index\": 0,\n    \"methodname\": \"core_calendar_get_action_events_by_timesort\",\n    \"args\": {\n      \"limitnum\": 20,\n      \"timesortfrom\": {{nowSec}},\n      \"limittononsuspendedevents\": true\n    }\n  },\n  {\n    \"index\": 1,\n    \"methodname\": \"core_calendar_get_action_events_by_timesort\",\n    \"args\": {\n      \"limitnum\": 20,\n      \"timesortfrom\": {{pastSec}},\n      \"timesortto\": {{nowSec}},\n      \"limittononsuspendedevents\": true\n    }\n  }\n]"
            },
            "url": {
              "raw": "{{baseUrl}}/lib/ajax/service.php?sesskey={{sesskey}}&info=core_calendar_get_action_events_by_timesort",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "lib",
                "ajax",
                "service.php"
              ],
              "query": [
                {
                  "key": "sesskey",
                  "value": "{{sesskey}}"
                },
                {
                  "key": "info",
                  "value": "core_calendar_get_action_events_by_timesort"
                }
              ]
            },
            "description": "Calls Moodle AJAX API for calendar action events. Two batched requests: upcoming (from now) and overdue (past 30 days). Output: JSON array of events with name, course, timesort, url. Visualize tab shows a table."
          },
          "response": []
        }
      ],
      "description": "Timeline events (assignments, quizzes, deadlines). Requires sesskey from Login step 3."
    },
