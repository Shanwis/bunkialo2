    {
      "name": "Resources",
      "item": [
        {
          "name": "Course Resources",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const html = pm.response.text();",
                  "const baseUrl = pm.collectionVariables.get('baseUrl') || '';",
                  "const strip = (s) => (s||'').replace(/<[^>]+>/g,' ').replace(/\\s+/g,' ').trim();",
                  "const toAbs = (href) => { if(!href) return ''; if(href.startsWith('http')) return href; if(href.startsWith('//')) return 'https:'+href; if(href.startsWith('/')) return baseUrl+href; return baseUrl+'/'+href.replace(/^\\.?\\//,''); };",
                  "const titleMatch = html.match(/<h1[^>]*>([^<]+)<\\/h1>/i);",
                  "const courseTitle = titleMatch ? strip(titleMatch[1]) : 'Course';",
                  "const sectionBlocks = html.split(/<li[^>]*class=\"[^\"]*section[^\"]*\"[^>]*>/i).slice(1);",
                  "const sections = [];",
                  "for (let i = 0; i < sectionBlocks.length; i++) {",
                  "  const block = sectionBlocks[i];",
                  "  const sectionTitleMatch = block.match(/<h3[^>]*sectionname[^>]*>([^<]+)<\\/h3>/i) || block.match(/<h3[^>]*>([^<]+)<\\/h3>/i);",
                  "  const sectionTitle = sectionTitleMatch ? strip(sectionTitleMatch[1]) : 'Section ' + (i+1);",
                  "  const activityMatches = block.match(/<li[^>]*class=\"[^\"]*activity[^\"]*\"[^>]*>[\\s\\S]*?<a[^>]*href=\"([^\"]+)\"[^>]*>([\\s\\S]*?)<\\/a>/gi) || [];",
                  "  const items = [];",
                  "  for (const am of activityMatches) {",
                  "    const modMatch = am.match(/modtype_([a-z0-9_]+)/i);",
                  "    const modType = modMatch ? modMatch[1].toLowerCase() : 'unknown';",
                  "    const hrefMatch = am.match(/href=\"([^\"]+)\"/i);",
                  "    const textMatch = am.match(/>([\\s\\S]*?)<\\/a>/i);",
                  "    const url = hrefMatch ? toAbs(hrefMatch[1]) : '';",
                  "    let title = textMatch ? strip(textMatch[1]) : '';",
                  "    const accessHide = title.match(/^(.*?)\\s+(File|Folder|Assignment|Quiz|Forum|Attendance|Resource)$/i);",
                  "    if (accessHide) title = accessHide[1].trim();",
                  "    if (title) items.push({ title, modType, url });",
                  "  }",
                  "  if (items.length) sections.push({ title: sectionTitle, items });",
                  "}",
                  "",
                  "pm.test('Course page loaded', () => pm.expect(html.length).to.be.above(100));",
                  "",
                  "// Prepare data with badge colors for each item",
                  "const badgeColors = {",
                  "  assign: '#e74c3c',",
                  "  assignment: '#e74c3c',",
                  "  quiz: '#9b59b6',",
                  "  folder: '#f39c12',",
                  "  resource: '#3498db',",
                  "  url: '#1abc9c',",
                  "  forum: '#2ecc71',",
                  "  attendance: '#e67e22',",
                  "  page: '#34495e',",
                  "  unknown: '#95a5a6'",
                  "};",
                  "",
                  "const sectionsWithColors = sections.map(function(sec) {",
                  "  return {",
                  "    title: sec.title,",
                  "    itemCount: sec.items.length,",
                  "    items: sec.items.map(function(item) {",
                  "      return {",
                  "        title: item.title,",
                  "        modType: item.modType,",
                  "        url: item.url,",
                  "        badgeColor: badgeColors[item.modType] || badgeColors.unknown",
                  "      };",
                  "    })",
                  "  };",
                  "});",
                  "var template = `",
                  "<style>",
                  "  * { box-sizing: border-box; }",
                  "",
                  "  body {",
                  "    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;",
                  "    margin: 0;",
                  "    padding: 24px;",
                  "    background: #0f1115;",
                  "    color: #e6e6e6;",
                  "  }",
                  "",
                  "  .header {",
                  "    background: #171a21;",
                  "    border: 1px solid #22252d;",
                  "    padding: 28px 32px;",
                  "    border-radius: 14px;",
                  "    margin-bottom: 28px;",
                  "    box-shadow: 0 8px 30px rgba(0,0,0,0.5);",
                  "  }",
                  "",
                  "  .header h1 {",
                  "    margin: 0;",
                  "    font-size: 26px;",
                  "    font-weight: 600;",
                  "    color: #ffffff;",
                  "  }",
                  "",
                  "  .header .subtitle {",
                  "    margin-top: 10px;",
                  "    font-size: 13px;",
                  "    color: #9aa0aa;",
                  "  }",
                  "",
                  "  /* Section Colors */",
                  "  .section-card {",
                  "    background: #15181f;",
                  "    border-radius: 12px;",
                  "    margin-bottom: 18px;",
                  "    overflow: hidden;",
                  "    transition: all 0.2s ease;",
                  "    border: 1px solid #20242c;",
                  "    border-left: 4px solid #3a3f4b;",
                  "  }",
                  "",
                  "  .section-card.color-0 { border-left-color: #4c6ef5; }  /* blue */",
                  "  .section-card.color-1 { border-left-color: #d6336c; }  /* crimson */",
                  "  .section-card.color-2 { border-left-color: #20c997; }  /* teal */",
                  "  .section-card.color-3 { border-left-color: #fab005; }  /* gold */",
                  "  .section-card.color-4 { border-left-color: #845ef7; }  /* violet */",
                  "  .section-card.color-5 { border-left-color: #ff922b; }  /* orange */",
                  "",
                  "  .section-card:hover {",
                  "    box-shadow: 0 6px 24px rgba(0,0,0,0.4);",
                  "    transform: translateY(-2px);",
                  "  }",
                  "",
                  "  .section-header {",
                  "    padding: 18px 22px;",
                  "    border-bottom: 1px solid #20242c;",
                  "    display: flex;",
                  "    justify-content: space-between;",
                  "    align-items: center;",
                  "  }",
                  "",
                  "  .section-title {",
                  "    font-size: 15px;",
                  "    font-weight: 600;",
                  "    color: #ffffff;",
                  "    margin: 0;",
                  "  }",
                  "",
                  "  .item-count {",
                  "    background: #2a2f3a;",
                  "    color: #cfd3da;",
                  "    padding: 4px 10px;",
                  "    border-radius: 20px;",
                  "    font-size: 11px;",
                  "    border: 1px solid #343a46;",
                  "  }",
                  "",
                  "  .items-list {",
                  "    padding: 10px 14px;",
                  "  }",
                  "",
                  "  .activity-item {",
                  "    display: flex;",
                  "    align-items: center;",
                  "    padding: 10px 8px;",
                  "    border-radius: 8px;",
                  "    transition: background 0.15s ease;",
                  "  }",
                  "",
                  "  .activity-item:hover {",
                  "    background: #1d212a;",
                  "  }",
                  "",
                  "  .badge {",
                  "    padding: 4px 10px;",
                  "    border-radius: 6px;",
                  "    font-size: 10px;",
                  "    font-weight: 600;",
                  "    text-transform: uppercase;",
                  "    margin-right: 14px;",
                  "    min-width: 72px;",
                  "    text-align: center;",
                  "    background: #2b2f38;",
                  "    color: #cfd3da;",
                  "    border: 1px solid #3a404c;",
                  "  }",
                  "",
                  "  .activity-link {",
                  "    color: #d7dbe2;",
                  "    text-decoration: none;",
                  "    font-size: 14px;",
                  "    flex: 1;",
                  "  }",
                  "",
                  "  .activity-link:hover {",
                  "    color: #ffffff;",
                  "  }",
                  "",
                  "  .no-sections {",
                  "    text-align: center;",
                  "    padding: 50px;",
                  "    color: #7a808a;",
                  "  }",
                  "</style>",
                  "",
                  "<div class=\"header\">",
                  "  <h1>{{courseTitle}}</h1>",
                  "  <div class=\"subtitle\">{{sectionCount}} sections · {{totalItems}} activities</div>",
                  "</div>",
                  "",
                  "{{#if sections}}",
                  "  {{#each sections}}",
                  "  <div class=\"section-card color-{{@index}}\">",
                  "    <div class=\"section-header\">",
                  "      <h3 class=\"section-title\">{{title}}</h3>",
                  "      <span class=\"item-count\">{{itemCount}} items</span>",
                  "    </div>",
                  "    <div class=\"items-list\">",
                  "      {{#each items}}",
                  "      <div class=\"activity-item\">",
                  "        <span class=\"badge\">{{modType}}</span>",
                  "        <a href=\"{{url}}\" target=\"_blank\" class=\"activity-link\">{{title}}</a>",
                  "      </div>",
                  "      {{/each}}",
                  "    </div>",
                  "  </div>",
                  "  {{/each}}",
                  "{{else}}",
                  "  <div class=\"no-sections\">No sections found in this course.</div>",
                  "{{/if}}",
                  "`;",
                  "",
                  "",
                  "function constructVisualizerPayload() {",
                  "  var totalItems = 0;",
                  "  for (var i = 0; i < sectionsWithColors.length; i++) {",
                  "    totalItems += sectionsWithColors[i].itemCount;",
                  "  }",
                  "  return {",
                  "    courseTitle: courseTitle,",
                  "    sections: sectionsWithColors,",
                  "    sectionCount: sectionsWithColors.length,",
                  "    totalItems: totalItems",
                  "  };",
                  "}",
                  "",
                  "pm.visualizer.set(template, constructVisualizerPayload());"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "User-Agent",
                "value": "Mozilla/5.0 (Linux; Android 10) AppleWebKit/537.36 Chrome/91.0.4472.120 Mobile"
              },
              {
                "key": "Accept",
                "value": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/course/view.php?id={{courseId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "course",
                "view.php"
              ],
              "query": [
                {
                  "key": "id",
                  "value": "{{courseId}}"
                }
              ]
            },
            "description": "Loads the course page with sections and activities. Output: HTML. Parsed like the app: sections (li.section), activities (li.activity) with modtype (assign, folder, resource, quiz, etc), title, url. Visualize tab shows a tree of sections and activity links."
          },
          "response": []
        }
      ],
      "description": "Course resources tree (sections and activities). Set courseId."
    }
